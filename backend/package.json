{
  "name": "crm2-backend",
  "version": "1.0.0",
  "description": "CRM2 Backend API",
  "main": "cmd/server/index.js",
  "scripts": {
    "start": "node cmd/server/index.js",
    "dev": "nodemon cmd/server/index.js",
    "migrate:diff": "atlas migrate diff --env local",
    "migrate:apply": "atlas migrate apply --env local",
    "migrate:status": "atlas migrate status --env local",
    "migrate:down": "atlas migrate down --env local",
    "migrate:lint": "atlas migrate lint --env local",
    "prisma:generate": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "casbin": "^5.50.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.10.1",
    "moment-timezone": "^0.6.2",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^7.8.0"
  },
  "prisma": {
    "schema": "internal/prisma/schema"
  }
